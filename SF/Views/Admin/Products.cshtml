@model SF.Models.AdminProductsPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sản phẩm";
    ViewData["Subtitle"] = "Thêm mới, chỉnh sửa và xóa sản phẩm trong hệ thống.";
}

<section class="admin-panel">
    <div class="admin-section-head">
        <div>
            <h2>Thêm sản phẩm</h2>
            <p>Tạo sản phẩm mới với đầy đủ giá, tồn kho, danh mục và NFT warranty.</p>
        </div>
    </div>

    <form method="post" action="/Admin/products/create" class="admin-form" style="margin-top:0">
        @Html.AntiForgeryToken()
        <div class="admin-field-grid">
            <div class="admin-field admin-field-full">
                <label>Tên sản phẩm</label>
                <input name="Name" value="@Model.NewProduct.Name" />
            </div>
            <div class="admin-field">
                <label>Danh mục</label>
                <select name="CategoryId">
                    @foreach (var category in Model.Categories)
                    {
                        if (category.CategoryId == Model.NewProduct.CategoryId)
                        {
                            <option selected="selected" value="@category.CategoryId">@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.CategoryId">@category.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="admin-field">
                <label>Tồn kho</label>
                <input type="number" name="Stock" min="0" value="@Model.NewProduct.Stock" />
            </div>
            <div class="admin-field">
                <label>Giá VND</label>
                <input type="number" step="1000" name="PriceVnd" min="0" value="@Model.NewProduct.PriceVnd" />
            </div>
            <div class="admin-field">
                <label>Giá Crypto</label>
                <input type="number" step="0.000001" name="PriceCrypto" min="0" value="@Model.NewProduct.PriceCrypto" />
            </div>
            <div class="admin-field admin-field-full">
                <label>Ảnh sản phẩm</label>
                <input name="ImageUrl" value="@Model.NewProduct.ImageUrl" />
            </div>
            <div class="admin-field">
                <label>Bật NFT bảo hành</label>
                <select name="NftWarrantyEnabled">
                    <option value="true" selected="selected">Có</option>
                    <option value="false">Không</option>
                </select>
            </div>
            <div class="admin-field">
                <label>Số tháng bảo hành</label>
                <input type="number" name="WarrantyMonths" min="1" value="@Model.NewProduct.WarrantyMonths" />
            </div>
        </div>
        <div class="admin-actions">
            <button type="submit" class="admin-btn admin-btn-primary">Thêm sản phẩm</button>
        </div>
    </form>
</section>

<section class="admin-panel" style="margin-top:20px">
    <div class="admin-section-head">
        <div>
            <h2>Danh sách sản phẩm</h2>
            <p>Chỉnh sửa trực tiếp từng sản phẩm hoặc xóa nếu chưa phát sinh đơn hàng.</p>
        </div>
    </div>

    <div class="admin-products-grid">
        @foreach (var product in Model.Products)
        {
            <div class="admin-card">
                <div class="admin-card-head">
                    <div>
                        <div class="admin-card-title">@( $"#P{product.ProductId:D4}" ) - @product.Name</div>
                        <div class="admin-card-meta">@product.CategoryName · Kho @product.Stock · @(product.NftWarrantyEnabled ? $"NFT {product.WarrantyMonths} tháng" : "Không có NFT")</div>
                    </div>
                </div>

                <form method="post" action="/Admin/products/update" class="admin-form" style="margin-top:0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductId" value="@product.ProductId" />
                    <div class="admin-field-grid">
                        <div class="admin-field admin-field-full">
                            <label>Tên sản phẩm</label>
                            <input name="Name" value="@product.Name" />
                        </div>
                        <div class="admin-field">
                            <label>Danh mục</label>
                            <select name="CategoryId">
                                @foreach (var category in Model.Categories)
                                {
                                    if (category.CategoryId == product.CategoryId)
                                    {
                                        <option selected="selected" value="@category.CategoryId">@category.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@category.CategoryId">@category.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="admin-field">
                            <label>Tồn kho</label>
                            <input type="number" name="Stock" min="0" value="@product.Stock" />
                        </div>
                        <div class="admin-field">
                            <label>Giá VND</label>
                            <input type="number" step="1000" name="PriceVnd" min="0" value="@product.PriceVnd" />
                        </div>
                        <div class="admin-field">
                            <label>Giá Crypto</label>
                            <input type="number" step="0.000001" name="PriceCrypto" min="0" value="@product.PriceCrypto" />
                        </div>
                        <div class="admin-field admin-field-full">
                            <label>Ảnh sản phẩm</label>
                            <input name="ImageUrl" value="@product.ImageUrl" />
                        </div>
                        <div class="admin-field">
                            <label>Bật NFT bảo hành</label>
                            <select name="NftWarrantyEnabled">
                                @if (product.NftWarrantyEnabled)
                                {
                                    <option selected="selected" value="true">Có</option>
                                    <option value="false">Không</option>
                                }
                                else
                                {
                                    <option value="true">Có</option>
                                    <option selected="selected" value="false">Không</option>
                                }
                            </select>
                        </div>
                        <div class="admin-field">
                            <label>Số tháng bảo hành</label>
                            <input type="number" name="WarrantyMonths" min="1" value="@product.WarrantyMonths" />
                        </div>
                    </div>
                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-primary">Lưu sản phẩm</button>
                    </div>
                </form>

                <form method="post" action="/Admin/products/delete" onsubmit="return confirm('Xóa sản phẩm này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product.ProductId" />
                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-danger">Xóa sản phẩm</button>
                    </div>
                </form>
            </div>
        }
    </div>
</section>
