  {
    id: 'fx1',
    name: 'Corsair Vengeance DDR5 32GB',
    category: 'RAM',
    price: 2190000,
    oldPrice: 2900000,
    nft: false,
    sale: true,
    image: 'inline:product-p4',
    icon: 'ðŸ’¾',
    specs: ['32GB Kit', 'DDR5', 'Heatspreader'],
    crypto: 'â‰ˆ 0.56 ETH',
    rating: 'â˜…â˜…â˜…â˜…â˜…',
    ratingCount: '(128)',
