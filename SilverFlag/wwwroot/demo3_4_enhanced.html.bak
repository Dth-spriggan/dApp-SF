    'build-pc': { category: 'TÃ¡ÂºÂ¥t cÃ¡ÂºÂ£', query: '', note: 'Má»¥c Build PC nÄ‚Âªn lÄ‚Â m sau bÃ¡ÂºÂ±ng combo cÃ¡ÂºÂ¥u hÄ‚Â¬nh sÃ¡ÂºÂµn' },
