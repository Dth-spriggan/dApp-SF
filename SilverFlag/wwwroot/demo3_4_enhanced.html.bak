function getProductFromModal() {
  const modal = document.querySelector(".modal"); // hoáº·c id modal cá»§a báº¡n

  const name = modal.querySelector("h2")?.innerText;

  const price = parseFloat(
    modal.querySelector(".price")?.innerText.replace(/\D/g, "")
  );

  const cryptoText = modal.querySelector(".prod-crypto")?.innerText;

  let eth = 0;

  if (cryptoText) {
    const match = cryptoText.match(/([\d.]+)\s*ETH/);
    if (match) eth = parseFloat(match[1]);
  }

  return {
    id: Date.now(),
    name,
    price,
    eth
  };
}

function handleAddClick(el) {
  const product = getProduct(el); // ðŸ”¥ táº¡o product táº¡i Ä‘Ã¢y
  addToCart(product);
}

function loadOrdersFromStorage() {
  const stored = JSON.parse(localStorage.getItem("orders") || "[]");

  if (!currentUser.accountData.orders) {
    currentUser.accountData.orders = [];
  }

  // trÃ¡nh trÃ¹ng
  stored.forEach(o => {
    if (!currentUser.accountData.orders.find(x => x.id === o.id)) {
      currentUser.accountData.orders.unshift(o);
    }
  });

  persistCurrentState();
}

function syncOrdersFromStorage() {
  const storedOrders = JSON.parse(localStorage.getItem("orders") || "[]");

  if (!currentUser) return;

  if (!currentUser.accountData) {
    currentUser.accountData = {};
  }

  if (!currentUser.accountData.orders) {
    currentUser.accountData.orders = [];
  }

  // trÃ¡nh trÃ¹ng Ä‘Æ¡n
  storedOrders.forEach(o => {
    if (!currentUser.accountData.orders.find(x => x.id === o.id)) {
      currentUser.accountData.orders.unshift(o);
    }
  });

  persistCurrentState();
}

// Xá»­ lÃ½ sau khi thanh toÃ¡n Crypto thÃ nh cÃ´ng
// ==================== CALLBACK SAU THANH TOÃN CRYPTO ====================
// ==================== Xá»¬ LÃ SAU KHI THANH TOÃN CRYPTO ====================
function handleCryptoPaymentCallback() {
  const urlParams = new URLSearchParams(window.location.search);
  
  if (urlParams.get("paid") === "1") {
    console.log("âœ… PhÃ¡t hiá»‡n thanh toÃ¡n thÃ nh cÃ´ng, Ä‘ang kiá»ƒm tra Ä‘Æ¡n hÃ ng...");

    // 1. Láº¥y Ä‘Æ¡n hÃ ng má»›i nháº¥t tá»« máº£ng "orders" (mÃ  trang crypto_payment vá»«a lÆ°u)
    let ordersFromStorage = JSON.parse(localStorage.getItem("orders") || "[]");
    
    if (ordersFromStorage.length > 0) {
      const newOrder = ordersFromStorage[0]; // Láº¥y Ä‘Æ¡n hÃ ng má»›i nháº¥t vá»«a thÃªm vÃ o Ä‘áº§u máº£ng

      // 2. KhÃ´i phá»¥c User (Äáº£m báº£o currentUser cÃ³ dá»¯ liá»‡u)
if (!currentUser) {
  const backup = localStorage.getItem("currentUserBackup");
  if (backup) {
    currentUser = JSON.parse(backup);
    simulateLogin(currentUser); // ðŸ”¥ Báº®T BUá»˜C
  }
}

      if (currentUser) {
        if (!currentUser.accountData) currentUser.accountData = { orders: [] };
        if (!currentUser.accountData.orders) currentUser.accountData.orders = [];

        // 3. Kiá»ƒm tra xem Ä‘Æ¡n nÃ y Ä‘Ã£ cÃ³ trong tÃ i khoáº£n chÆ°a (trÃ¡nh trÃ¹ng láº·p)
        const isExisted = currentUser.accountData.orders.some(o => o.id === newOrder.id);
        
        if (!isExisted) {
          console.log("ðŸ“¦ Äang náº¡p Ä‘Æ¡n hÃ ng má»›i vÃ o tÃ i khoáº£n:", newOrder.id);
          currentUser.accountData.orders.unshift(newOrder);

          // 4. LÆ¯U VÄ¨NH VIá»„N VÃ€O Há»† THá»NG Tá»”NG
          // Gá»i persistCurrentState Ä‘á»ƒ ghi Ä‘Ã¨ vÃ o SILVER_FLAG_USERS_DATA
          if (typeof persistCurrentState === "function") {
            persistCurrentState();
          } else {
            // Náº¿u khÃ´ng cÃ³ hÃ m persist, ta tá»± lÆ°u vÃ o máº£ng users tá»•ng
            let allUsers = JSON.parse(localStorage.getItem("SILVER_FLAG_USERS_DATA") || "[]");
            const idx = allUsers.findIndex(u => u.username === currentUser.username);
            if (idx !== -1) {
              allUsers[idx] = currentUser;
              localStorage.setItem("SILVER_FLAG_USERS_DATA", JSON.stringify(allUsers));
            }
          }
          
          // 5. Váº½ láº¡i báº£ng ngay láº­p tá»©c
          if (typeof renderAccountData === "function") renderAccountData();
        }
      }
    }

    showToast("ðŸŽ‰ Thanh toÃ¡n thÃ nh cÃ´ng! ÄÆ¡n hÃ ng Ä‘Ã£ Ä‘Æ°á»£c cáº­p nháº­t.", "");

    // XÃ³a dáº¥u váº¿t vÃ  dá»n dáº¹p
    window.history.replaceState({}, document.title, window.location.pathname);
    setTimeout(() => {
  localStorage.removeItem("currentUserBackup");
}, 3000);
    // localStorage.removeItem("orders"); // TÃ¹y chá»n: XÃ³a máº£ng táº¡m náº¿u muá»‘n sáº¡ch sáº½
  }
}

function restoreUserAfterCryptoPayment() {
  const urlParams = new URLSearchParams(window.location.search);
  
  if (urlParams.get("paid") === "1") {
    console.log("ðŸ”„ Äang khÃ´i phá»¥c sau thanh toÃ¡n Crypto...");

    // 1. KhÃ´i phá»¥c Ä‘Äƒng nháº­p
    const savedUser = localStorage.getItem("currentUser");
    if (savedUser && (!currentUser || !currentUser.name)) {
      try {
        currentUser = JSON.parse(savedUser);
        simulateLogin(currentUser);   // hÃ m nÃ y cá»§a báº¡n sáº½ cáº­p nháº­t UI
        console.log("âœ… KhÃ´i phá»¥c Ä‘Äƒng nháº­p thÃ nh cÃ´ng");
      } catch(e) { console.error("Lá»—i khÃ´i phá»¥c user", e); }
    }

    // 2. Äá»“ng bá»™ Ä‘Æ¡n hÃ ng
    if (typeof syncOrdersFromStorage === "function") {
      syncOrdersFromStorage();
      console.log("âœ… ÄÃ£ cháº¡y syncOrdersFromStorage");
    } else {
      // Fallback trá»±c tiáº¿p
      const storedOrders = JSON.parse(localStorage.getItem("orders") || "[]");
      if (currentUser && currentUser.accountData) {
        if (!currentUser.accountData.orders) currentUser.accountData.orders = [];
        storedOrders.forEach(order => {
          if (!currentUser.accountData.orders.find(o => o.id === order.id)) {
            currentUser.accountData.orders.unshift(order);
          }
        });
        renderAccountData();   // hÃ m render Ä‘Æ¡n hÃ ng cá»§a báº¡n
      }
    }

    showToast("ðŸŽ‰ Thanh toÃ¡n Crypto thÃ nh cÃ´ng! ÄÆ¡n hÃ ng Ä‘Ã£ Ä‘Æ°á»£c cáº­p nháº­t.", "");

    window.history.replaceState({}, document.title, window.location.pathname);
  }
}


// ====================== KHÃ”I PHá»¤C ÄÄ‚NG NHáº¬P + ÄÆ N HÃ€NG SAU CRYPTO PAYMENT ======================
function restoreAfterCryptoPayment() {
  const urlParams = new URLSearchParams(window.location.search);
  
  if (urlParams.get("paid") !== "1") return;

  console.log("ðŸ”„ Äang khÃ´i phá»¥c sau thanh toÃ¡n Crypto...");

  // 1. KhÃ´i phá»¥c Ä‘Äƒng nháº­p
  const backup = localStorage.getItem("currentUserBackup");
  if (backup) {
    try {
      currentUser = JSON.parse(backup);
      simulateLogin(currentUser);        // hÃ m nÃ y sáº½ cáº­p nháº­t UI
      console.log("âœ… ÄÃ£ khÃ´i phá»¥c Ä‘Äƒng nháº­p thÃ nh cÃ´ng");
    } catch (e) {
      console.error("Lá»—i khÃ´i phá»¥c user", e);
    }
  }

  // 2. Äá»“ng bá»™ Ä‘Æ¡n hÃ ng
  const ordersFromStorage = JSON.parse(localStorage.getItem("orders") || "[]");
  if (currentUser && currentUser.accountData) {
    if (!currentUser.accountData.orders) currentUser.accountData.orders = [];
    
    ordersFromStorage.forEach(order => {
      if (!currentUser.accountData.orders.find(o => o.id === order.id)) {
        currentUser.accountData.orders.unshift(order);
      }
    });
    
    renderAccountData();   // hÃ m render Ä‘Æ¡n hÃ ng cá»§a báº¡n
    persistCurrentState();
    console.log("âœ… ÄÃ£ Ä‘á»“ng bá»™ Ä‘Æ¡n hÃ ng, tá»•ng Ä‘Æ¡n:", currentUser.accountData.orders.length);
  }

  showToast("ðŸŽ‰ Thanh toÃ¡n Crypto thÃ nh cÃ´ng! ÄÆ¡n hÃ ng Ä‘Ã£ Ä‘Æ°á»£c cáº­p nháº­t.", "");

  // XÃ³a param URL vÃ  dá»¯ liá»‡u táº¡m
  window.history.replaceState({}, document.title, window.location.pathname);
  localStorage.removeItem("justPaidCrypto");
}

window.addEventListener('load', function () {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("paid") !== "1") return;

    console.log("ðŸ”¥ Crypto callback triggered");

    // 1. Láº¥y backup
    const backup = localStorage.getItem("currentUserBackup");
    let backupUser = backup ? JSON.parse(backup) : null;

    // 2. Náº¿u chÆ°a cÃ³ currentUser â†’ restore + login
if (!currentUser && backupUser && urlParams.get("paid") === "1") {
    currentUser = backupUser;
    simulateLogin(currentUser);
}

    // 3. Merge orders tá»« backup
    if (currentUser && backupUser?.accountData?.orders) {
        if (!currentUser.accountData) currentUser.accountData = { orders: [], nfts: [] };
        if (!currentUser.accountData.orders) currentUser.accountData.orders = [];

        backupUser.accountData.orders.forEach(order => {
            if (!currentUser.accountData.orders.find(o => o.id === order.id)) {
                currentUser.accountData.orders.unshift(order);
            }
        });
    }

    // 4. Merge tá»« orders chung (fallback)
    const ordersFromStorage = JSON.parse(localStorage.getItem("orders") || "[]");

    if (currentUser && ordersFromStorage.length > 0) {
        if (!currentUser.accountData) currentUser.accountData = { orders: [], nfts: [] };
        if (!currentUser.accountData.orders) currentUser.accountData.orders = [];

        ordersFromStorage.forEach(order => {
            if (!currentUser.accountData.orders.find(o => o.id === order.id)) {
                currentUser.accountData.orders.unshift(order);
            }
        });
    }

    // 5. Render + persist
    if (currentUser) {
        console.log("âœ… Render láº¡i UI + lÆ°u state");

        if (typeof renderAccountData === "function") renderAccountData();
        if (typeof persistCurrentState === "function") persistCurrentState();
    }

    showToast("ðŸŽ‰ Thanh toÃ¡n Crypto thÃ nh cÃ´ng! ÄÆ¡n hÃ ng Ä‘Ã£ Ä‘Æ°á»£c cáº­p nháº­t.", "");

    // 6. Cleanup AN TOÃ€N (delay Ä‘á»ƒ trÃ¡nh race condition)
    setTimeout(() => {
        console.log("ðŸ§¹ XoÃ¡ backup sau khi hoÃ n táº¥t");
        localStorage.removeItem("currentUserBackup");
    }, 1500);

    // 7. XoÃ¡ query param
    window.history.replaceState({}, document.title, window.location.pathname);
});
</script>
