        <span class="section-icon">🔥</span>
        <span class="section-title">SẢN PHẨM NỔI BẬT</span>
        <div class="section-tabs">
          <div class="sec-tab active" onclick="setTab(this)">Tất cả</div>
          <div class="sec-tab" onclick="setTab(this)">GPU</div>
          <div class="sec-tab" onclick="setTab(this)">CPU</div>
          <div class="sec-tab" onclick="setTab(this)">RAM</div>
          <div class="sec-tab" onclick="setTab(this)">SSD</div>
        </div>
      </div>
      <span class="see-all" onclick="showToast('Xem tất cả sản phẩm', 'info')">Xem tất cả ›</span>
    </div>

    <div class="catalog-toolbar">
      <div class="catalog-summary">Đang hiển thị <strong id="catalogResultCount">5</strong> sản phẩm phù hợp</div>
      <div class="catalog-tools">
        <button class="catalog-chip" id="filterNftBtn" onclick="toggleCatalogFlag('nft')">◈ Chỉ NFT</button>
        <button class="catalog-chip" id="filterSaleBtn" onclick="toggleCatalogFlag('sale')">🏷️ Đang giảm giá</button>
        <select class="catalog-sort" id="catalogSort" onchange="changeCatalogSort(this.value)">
          <option value="featured">Sắp xếp: Nổi bật</option>
          <option value="price-asc">Giá tăng dần</option>
          <option value="price-desc">Giá giảm dần</option>
          <option value="name-asc">Tên A-Z</option>
        </select>
        <button class="catalog-reset" onclick="resetCatalogFilters()">Xóa bộ lọc</button>
      </div>
    </div>

    <div class="product-grid" id="featuredProductGrid">

