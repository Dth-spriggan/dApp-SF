<!-- ─── AUTH MODAL ─── -->
<div class="auth-modal-overlay" id="authModal" onclick="authOverlayClick(event)">
  <div class="auth-modal">

    <div class="auth-modal-banner">
      <div class="auth-close-btn" onclick="closeAuthModal()">✕</div>
      <div class="auth-modal-logo">Silver<span>Flag</span>PC</div>
      <div class="auth-tagline">Chính hãng · Web3 · NFT bảo hành</div>
    </div>

    <div class="auth-tabs">
      <div class="auth-tab active" id="tabLogin" onclick="switchAuthTab('login')">Đăng nhập</div>
      <div class="auth-tab" id="tabRegister" onclick="switchAuthTab('register')">Đăng ký</div>
    </div>

    <!-- LOGIN FORM -->
    <div class="auth-body" id="formLogin">
      <div class="auth-form-group">
        <label class="auth-label">Email hoặc số điện thoại</label>
        <input class="auth-input" id="loginEmail" type="text" placeholder="email@example.com" oninput="clearAuthErr('loginEmailErr')">
        <div class="auth-error-msg" id="loginEmailErr">Vui lòng nhập email hợp lệ</div>
      </div>
      <div class="auth-form-group">
        <label class="auth-label">Mật khẩu</label>
        <div class="auth-input-wrap">
          <input class="auth-input" id="loginPw" type="password" placeholder="Nhập mật khẩu" oninput="clearAuthErr('loginPwErr')">
          <span class="auth-eye" onclick="togglePw('loginPw',this)">👁</span>
        </div>
        <div class="auth-error-msg" id="loginPwErr">Mật khẩu không đúng</div>
      </div>
      <div class="auth-row">
        <label class="auth-check-label">
          <input type="checkbox" id="rememberMe" checked> Ghi nhớ đăng nhập
        </label>
        <span class="auth-forgot" onclick="showForgotPw()">Quên mật khẩu?</span>
      </div>
      <button class="auth-submit-btn" id="loginBtn" onclick="doLogin()">Đăng nhập</button>
      <div class="auth-divider">hoặc tiếp tục với</div>
      <div class="auth-social-btns">
        <button class="auth-social-btn" onclick="socialLogin('Web3')">◈ Ví Web3</button>
      </div>
      <div class="auth-footer-text">Chưa có tài khoản? <span onclick="switchAuthTab('register')">Đăng ký ngay</span></div>
    </div>

    <!-- REGISTER FORM -->
    <div class="auth-body" id="formRegister" style="display:none">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div class="auth-form-group">
          <label class="auth-label">Họ</label>
          <input class="auth-input" id="regLast" type="text" placeholder="Nguyễn">
        </div>
        <div class="auth-form-group">
          <label class="auth-label">Tên</label>
          <input class="auth-input" id="regFirst" type="text" placeholder="Văn A">
        </div>
      </div>
      <div class="auth-form-group">
        <label class="auth-label">Email</label>
        <input class="auth-input" id="regEmail" type="email" placeholder="email@example.com" oninput="clearAuthErr('regEmailErr')">
        <div class="auth-error-msg" id="regEmailErr">Email không hợp lệ hoặc đã tồn tại</div>
      </div>
      <div class="auth-form-group">
        <label class="auth-label">Số điện thoại</label>
        <input class="auth-input" id="regPhone" type="tel" placeholder="0912 345 678">
      </div>
      <div class="auth-form-group">
        <label class="auth-label">Mật khẩu</label>
        <div class="auth-input-wrap">
          <input class="auth-input" id="regPw" type="password" placeholder="Tối thiểu 8 ký tự" oninput="checkPwStrength(this.value)">
          <span class="auth-eye" onclick="togglePw('regPw',this)">👁</span>
        </div>
        <div class="pw-strength"><div class="pw-strength-fill" id="pwStrengthBar" style="width:0%;background:var(--red)"></div></div>
        <div style="font-size:11px;color:var(--text-3);margin-top:4px" id="pwStrengthTxt"></div>
      </div>
      <div class="auth-form-group" style="margin-bottom:18px">
        <label class="auth-label">Xác nhận mật khẩu</label>
        <input class="auth-input" id="regPw2" type="password" placeholder="Nhập lại mật khẩu" oninput="clearAuthErr('regPw2Err')">
        <div class="auth-error-msg" id="regPw2Err">Mật khẩu không khớp</div>
      </div>
      <button class="auth-submit-btn" id="registerBtn" onclick="doRegister()">Tạo tài khoản</button>
      <div class="auth-footer-text" style="margin-top:12px">Đã có tài khoản? <span onclick="switchAuthTab('login')">Đăng nhập</span></div>
    </div>

  </div>
</div>

