<!-- Checkout Modal -->
<div class="modal-overlay" id="checkoutModal" onclick="closeModalOutside(event,'checkoutModal')">
  <div class="modal-box">
    <div class="modal-head">
      <div class="modal-title">🛒 Thanh Toán Đơn Hàng</div>
      <span class="modal-close" onclick="closeModal('checkoutModal')">✕</span>
    </div>
    <div class="modal-body">
      <div class="checkout-grid">
        <div>
          <div class="form-group">
